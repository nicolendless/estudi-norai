---
import '../styles/global.css';
---

<html>
  <head>
    <meta charset="utf-8" />
    <title></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@200;300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="font-archivo font-extralight">
    <header class="pointer-events-none fixed inset-x-0 top-0 z-[60]">
      <!-- <button
        type="button"
        aria-label="Open menu"
        class="pointer-events-auto absolute top-4 left-6 inline-flex h-12 w-12 items-center justify-center"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-12 w-12"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
        >
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"></path>
        </svg>
      </button> -->
      <div class="flex justify-end px-4 pt-5 md:px-8 md:pt-8">
        <a href="/" class="pointer-events-auto">
          <img
            src="/images/logo.svg"
            alt="Estudi Norai logo"
            data-site-logo
            class="site-logo h-14 w-auto transition-[filter] duration-300 md:h-16"
          />
        </a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="w-full bg-white px-6 py-6 text-center text-sm text-zinc-800">
      <div class="flex flex-wrap items-center justify-center gap-3">
        <span>@Copyright Estudio Norai</span>
        <span>-</span>
        <a href="#" class="underline">Protección de datos</a>
        <span>-</span>
        <a href="#" class="underline">Política de privacidad</a>
        <span>-</span>
        <a href="#" class="underline">Política de cookies</a>
        <span>-</span>
        <a href="#" class="underline">Política de privacidad de la app</a>
      </div>
    </footer>

    <script>
      const logo = document.querySelector<HTMLImageElement>('[data-site-logo]');

      const mobileSectionThemes: Record<string, 'light' | 'dark'> = {
        menu: 'light',
        intro: 'dark',
        servicios: 'dark',
        conoceme: 'light',
        embarcacion: 'light',
        material: 'dark',
        spotify: 'dark',
        artistas: 'dark',
        contacto: 'light',
        visitanos: 'dark',
      };

      const desktopSectionThemes: Record<string, 'light' | 'dark'> = {
        menu: 'dark',
        intro: 'dark',
        servicios: 'dark',
        conoceme: 'light',
        embarcacion: 'light',
        material: 'dark',
        spotify: 'dark',
        artistas: 'dark',
        contacto: 'light',
        visitanos: 'dark',
      };

      const applyLogoTheme = (theme: 'light' | 'dark') => {
        if (!logo) return;
        logo.classList.toggle('site-logo-dark', theme === 'dark');
        logo.classList.toggle('site-logo-light', theme === 'light');
      };

      const updateLogoTheme = () => {
        if (!logo) return;

        if (document.body.classList.contains('hero-menu-open')) {
          applyLogoTheme('dark');
          return;
        }

        const marker = window.scrollY + 96;
        const sections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));

        let activeId = 'menu';

        for (const section of sections) {
          if (section.offsetTop <= marker) {
            activeId = section.id;
          } else {
            break;
          }
        }

        const themeMap = window.innerWidth >= 768 ? desktopSectionThemes : mobileSectionThemes;
        applyLogoTheme(themeMap[activeId] ?? 'dark');
      };

      window.addEventListener('scroll', updateLogoTheme, { passive: true });
      window.addEventListener('resize', updateLogoTheme);
      updateLogoTheme();
    </script>
  </body>
</html>

<style>
  .site-logo-dark {
    filter: brightness(0) saturate(100%);
  }

  .site-logo-light {
    filter: brightness(0) saturate(100%) invert(95%) sepia(23%) saturate(475%) hue-rotate(322deg)
      brightness(101%) contrast(92%);
  }
</style>

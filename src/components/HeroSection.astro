  </div>
</section>

<script>
  const menuToggle = document.querySelector<HTMLButtonElement>('[data-hero-menu-toggle]');
  const menuClose = document.querySelector<HTMLButtonElement>('[data-hero-menu-close]');
  const mobileMenu = document.getElementById('hero-mobile-menu');
  const mobileLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('#hero-mobile-menu a'),
  );

  const closeMenu = () => {
    if (!mobileMenu) return;
    mobileMenu.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
    document.body.classList.remove('hero-menu-open');
    menuToggle?.classList.remove('invisible');
    window.dispatchEvent(new Event('scroll'));
  };

  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
      document.body.classList.add('hero-menu-open');
      menuToggle.classList.add('invisible');
      window.dispatchEvent(new Event('scroll'));
    });
  }

  if (menuClose) {
    menuClose.addEventListener('click', closeMenu);
  }

  mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));
</script>

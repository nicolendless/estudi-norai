<section id="contacto" class="relative flex min-h-[68vh] w-full flex-col bg-cyan-950 py-10 md:py-14 lg:flex-row">
  <div class="order-2 flex w-full items-center justify-center px-6 md:px-10 lg:order-1 lg:w-1/2 lg:px-12">
    <form action="/api/contact" method="post" data-contact-form class="w-full max-w-md space-y-3">
      <input
        type="text"
        name="nombre"
        placeholder="Nombre*"
        required
        class="w-full rounded-2xl bg-amber-50 px-5 py-2 text-center text-zinc-800 outline-none"
      />
      <input
        type="email"
        name="email"
        placeholder="Correo electrónico*"
        required
        class="w-full rounded-2xl bg-amber-50 px-5 py-2 text-center text-zinc-800 outline-none"
      />
      <input
        type="tel"
        name="telefono"
        placeholder="Teléfono"
        class="w-full rounded-2xl bg-amber-50 px-5 py-2 text-center text-zinc-800 outline-none"
      />
      <textarea
        name="mensaje"
        rows="4"
        placeholder="Proyecto / Idea
Déjame un mensaje"
        class="w-full resize-none rounded-2xl bg-amber-50 px-5 py-4 text-center text-zinc-800 outline-none"
      ></textarea>
      <div class="space-y-2 text-sm text-amber-50 md:text-base">
        <label class="flex items-start gap-2">
          <input type="checkbox" name="politica" class="accent-amber-50" required />
          <span>Acepto la política de protección de datos</span>
        </label>
        <label class="flex items-start gap-2">
          <input type="checkbox" name="comerciales" class="accent-amber-50" />
          <span>Acepto recibir novedades comerciales</span>
        </label>
      </div>
      <div class="flex justify-end">
        <button
          type="submit"
          class="font-archivo rounded-2xl bg-cyan-900 px-4 py-1 text-amber-50 hover:bg-cyan-800"
        >
          Enviar
        </button>
      </div>
      <p id="contact-feedback" class="hidden rounded-xl px-4 py-2 text-sm text-amber-50"></p>
    </form>
  </div>
  <div class="order-1 relative flex w-full items-center justify-center px-6 pb-8 md:px-10 md:pb-10 lg:order-2 lg:w-1/2 lg:px-12 lg:pb-0">
    <h2
      class="font-archivo text-center text-[16vw] leading-[0.95] tracking-tight text-amber-50 sm:text-[14vw] md:text-[12vw] lg:text-[11vw] xl:text-[10vw]"
    >
      <span class="block">TRABA</span>
      <span class="block">JEMOS</span>
      <span class="block">JUNTOS</span>
    </h2>
  </div>
  <div class="absolute top-0 right-4 hidden pt-10 md:right-5 md:pt-14 lg:block">
    <span
      class="font-archivo inline-block text-base text-amber-50 [writing-mode:vertical-rl] md:text-lg lg:text-2xl"
    >
      Embárcate
    </span>
  </div>
</section>

<script>
  import '../scripts/contact-form';
</script>

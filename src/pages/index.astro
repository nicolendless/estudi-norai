---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section id="menu" class="flex h-screen">
    <div class="relative h-full w-[65%]">
      <img src="/images/door_home_1.jpg" class="h-full w-full object-cover object-[50%_50%]" />
      <div class="absolute inset-0 flex items-center justify-center pr-4 pl-8 md:pr-8 md:pl-12">
        <h1
          class="font-archivo text-center text-5xl leading-tight text-white md:text-6xl lg:text-6xl xl:text-7xl"
        >
          <span class="block">TALLER DE PRODUCCIÓN MUSICAL Y</span>
          <span class="block">ESCUELA DE MÚSICA EN PALMA</span>
        </h1>
      </div>
    </div>
    <div class="relative h-full w-[35%] bg-amber-50">
      <nav aria-label="Sections" class="absolute inset-0">
        <!-- LINEA CURVA UNION
        <svg
          width="257"
          height="364"
          viewBox="0 0 257 364"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M0.171875 48.9712C3.17188 43.9712 131.172 -47.0288 163.172 32.9712C188.772 96.9712 235.839 130.305 256.172 138.971C176.172 160.971 14.5719 212.571 8.17188 242.971C0.171875 280.971 247.172 228.971 222.172 289.971C202.172 338.771 201.172 358.971 203.172 362.971"
            stroke="black"
            stroke-width="0.4"></path>
        </svg> -->

        <a
          href="#servicios"
          class="font-archivo absolute top-[8%] left-1/2 z-10 -translate-x-1/2 text-center md:top-[12%]"
        >
          <span class="block text-xl md:text-2xl lg:text-2xl xl:text-3xl">Ruta</span>
          <span
            class="ml-2 block text-sm font-light italic md:ml-4 md:text-base lg:text-lg xl:text-xl"
            >Servicios que ofrecemos</span
          >
        </a>
        <a
          href="#conoceme"
          class="font-archivo absolute top-[25%] right-[25%] z-10 text-center md:top-[30%] md:right-[30%]"
        >
          <span class="block text-xl md:text-2xl lg:text-2xl xl:text-3xl">Timonel</span>
          <span
            class="ml-2 block text-sm font-light italic md:ml-4 md:text-base lg:text-lg xl:text-xl"
            >Conóceme</span
          >
        </a>
        <a
          href="#embarcacion"
          class="font-archivo absolute top-[42%] left-[20%] z-10 text-center md:top-[48%] md:left-[25%]"
        >
          <span class="block text-xl md:text-2xl lg:text-2xl xl:text-3xl">Embarcación</span>
          <span
            class="ml-2 block text-sm font-light italic md:ml-4 md:text-base lg:text-lg xl:text-xl"
            >El Estudio</span
          >
        </a>
        <a
          href="#artistas"
          class="font-archivo absolute top-[60%] right-[25%] z-10 text-center md:top-[66%] md:right-[30%]"
        >
          <span class="block text-xl md:text-2xl lg:text-2xl xl:text-3xl">Tripulación</span>
          <span
            class="ml-2 block text-sm font-light italic md:ml-4 md:text-base lg:text-lg xl:text-xl"
            >Artistas / Proyectos</span
          >
        </a>
        <a
          href="#contacto"
          class="font-archivo absolute bottom-[8%] left-1/2 z-10 -translate-x-1/2 text-center md:bottom-[12%]"
        >
          <span class="block text-xl md:text-2xl lg:text-2xl xl:text-3xl">Póngamos Rumbo</span>
          <span
            class="ml-2 block text-sm font-light italic md:ml-4 md:text-base lg:text-lg xl:text-xl"
            >Trabajemos juntos</span
          >
        </a>
      </nav>
    </div>
  </section>

  <section id="footer-menu" class="absolute bottom-0 left-0 z-10 w-full bg-cyan-950 py-2">
    <div class="flex">
      <div class="w-[70%] pl-8 text-left text-lg text-white">+34 668 900 448</div>
      <div class="w-[30%] pr-8 text-right text-lg text-white">estudio-norai@gmail.com</div>
    </div>
  </section>

  <section id="intro" class="pt-20 pb-8">
    <div class="mx-auto max-w-5xl px-6 sm:px-8 lg:px-12">
      <p class="text-center text-[25px] leading-[32px]">
        Estudi Norai es un espacio de <strong>acompañamiento musical Km0</strong> en el centro de Palma
        de Mallorca. Como el Norai amarra las embarcaciones a puerto, este es el punto de anclaje para
        tu proyecto musical.
        <span class="block"
          >Un espacio donde las ideas toman forma y encuentran su propio ritmo.</span
        >
      </p>
      <p class="mt-6 text-center underline">
        <a href="#contacto" class="text-[25px]">Contacta ya</a>
      </p>
    </div>
    <div class="mt-6 flex justify-center">
      <div class="h-25 w-px bg-black"></div>
    </div>
  </section>

  <section id="servicios" class="mx-12 flex pb-20 md:mx-16 lg:mx-20 xl:mx-24">
    <div class="flex flex-1 flex-col">
      <div class="h-[60vh] bg-gray-200">
        <img src="/images/composicion.jpg" class="h-full w-full object-cover" />
      </div>
      <div class="flex flex-1 justify-center border bg-white p-6">
        <p class="text-center text-2xl text-black">Acompañamiento y Producción musical</p>
      </div>
    </div>
    <div class="flex flex-1 flex-col">
      <div class="flex h-[60vh] flex-col justify-between bg-amber-50 p-10 text-center">
        <p class="mb-4 text-4xl">Acompañamiento musical</p>
        <div class="px-4">
          <h2 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl">
            <span class="block">PRODU</span>
            <span class="block">CCIÓN</span>
          </h2>
        </div>
      </div>
      <div class="flex flex-1 justify-center border bg-white p-6">
        <p class="text-center text-2xl text-black">Grabación de videoclip en directo</p>
      </div>
    </div>
    <div class="flex flex-1 flex-col">
      <div class="h-[60vh] bg-gray-200">
        <img src="/images/formacion.jpg" class="h-full w-full object-cover" />
      </div>
      <div class="flex flex-1 justify-center border bg-white p-6">
        <p class="text-center text-2xl text-black">Formación Musical</p>
      </div>
    </div>
    <div class="flex flex-1 flex-col">
      <div class="h-[60vh] bg-gray-200">
        <img src="/images/mezcla.jpg" class="h-full w-full object-cover" />
      </div>
      <div class="flex flex-1 justify-center border bg-white p-6">
        <p class="text-center text-2xl text-black">Mezcla y Mastering</p>
      </div>
    </div>
  </section>

  <section id="conoceme" class="ml-12 flex pt-16 pb-0 md:ml-16 md:pt-24 md:pb-0 lg:ml-20 xl:ml-24">
    <div class="flex flex-1 flex-col p-10 text-left text-xl">
      <p class="mb-4">
        Mi pasión por la música viene prácticamente de nacimiento, ya que mis padres se conocieron
        en una coral. Desde pequeño, he vivido rodeado de música, tanto a nivel pasional como
        formativo, tomando clases de piano, guitarra y solfeo durante toda mi infancia y
        adolescencia.
      </p>
      <p class="mb-4">
        Durante la adolescencia inicié mis primeros proyectos musicales, como artista e intérprete.
        Algunas de estas bandas siguen vigentes a día de hoy. Pese a que mi arranque universitario y
        laboral fue en el mundo empresarial, poco a poco mi carrera fue girando hacia la música,
        pasando por Ticketmaster, hasta llegar a graduarme con honores, en
        <strong>Producción Músical en Barcelona, en la escuela Microfusa.</strong>
      </p>
      <p class="mb-4">
        En 2022, después de finalizar mis estudios en Microfusa y mudarme a Mallorca, decidí dar el
        paso a abrir mi propio estudio de música, lo que ahora ya conocéis como Estudi Norai. En
        esta etapa, he podido acompañar a artistas de muchas maneras, en proyectos maravillosos.
        Además, tengo la suerte de estar ligado a la música también como artista (Norai), intérprete
        (FincaMusicBand, Fonoll…), organizador de eventos (Rodautors) e incluso como profesor de
        guitarra y producción.
      </p>
    </div>
    <div class="relative flex min-h-[50vh] flex-1 flex-col md:min-h-[60vh]">
      <img src="/images/conoceme.png" alt="Timonel" class="h-full w-full object-cover" />
      <div class="absolute inset-0 flex items-end justify-center pb-6 md:pb-8">
        <h2 class="font-archivo text-4xl text-white md:text-5xl lg:text-6xl xl:text-7xl">
          CONÓCEME
        </h2>
      </div>
      <div class="absolute top-0 right-6 pt-16 md:top-0 md:right-5 md:pt-15">
        <span
          class="font-archivo inline-block text-base text-white [writing-mode:vertical-rl] md:text-lg lg:text-2xl"
        >
          Timonel
        </span>
      </div>
    </div>
  </section>

  <section id="embarcacion" class="relative h-[60vh] w-full">
    <img
      src="/images/embarcacion.jpg"
      alt="El Estudio"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="pointer-events-none absolute inset-x-0 top-2 bottom-2">
      <img
        src="/images/norai_letters.png"
        alt=""
        class="h-full w-full scale-110 object-contain md:scale-125"
      />
    </div>
    <div class="absolute inset-0 mx-12 md:mx-16 lg:mx-20 xl:mx-24">
      <div class="absolute inset-0 flex flex-col items-center justify-center">
        <h2 class="font-archivo text-4xl text-white md:text-5xl lg:text-6xl xl:text-7xl">
          El Estudio
        </h2>
        <a href="#servicios" class="font-archivo mt-3 text-white underline">Saber más</a>
      </div>
    </div>
    <div class="absolute top-0 right-6 pt-16 md:top-0 md:right-5 md:pt-15">
      <span
        class="font-archivo inline-block text-base text-white [writing-mode:vertical-rl] md:text-lg lg:text-2xl"
      >
        Embarcación
      </span>
    </div>
  </section>

  <section id="material" class="h-[45vh] w-full bg-amber-50 px-8 py-10 md:px-12 md:py-12">
    <div class="flex justify-end text-right">
      <div>
        <h2 class="font-archivo text-3xl text-zinc-800 md:text-4xl">
          Instrumentos y material disponible
        </h2>
        <a href="#contacto" class="font-archivo mt-1 inline-block text-lg text-zinc-700 underline"
          >Saber más</a
        >
      </div>
    </div>
  </section>

  <section
    id="spotify"
    class="mx-8 my-10 flex items-center justify-center rounded-2xl bg-white px-6 py-10 md:mx-12 md:my-14 md:min-h-[50vh] md:px-8 lg:mx-16 xl:mx-20"
  >
    <div class="w-full max-w-3xl">
      <iframe
        title="Spotify Player"
        src="https://open.spotify.com/embed/playlist/37i9dQZF1DXcBWIGoYBM5M?utm_source=generator"
        class="h-[152px] w-full sm:h-[232px] md:h-[352px]"
        frameborder="0"
        allowfullscreen=""
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"></iframe>
    </div>
  </section>

  <section id="artistas" class="flex h-[75vh] w-full">
    <div class="relative flex w-1/2 flex-col items-center justify-end bg-cyan-950 pb-6 md:pb-8">
      <h2
        class="font-archivo text-[22vw] leading-none tracking-tight text-amber-50 md:text-[17vw] lg:text-[14vw] xl:text-[12vw]"
      >
        WORKS
      </h2>
      <a href="#contacto" class="font-archivo mt-2 text-lg text-amber-50 underline">Saber más</a>
    </div>
    <div class="relative w-1/2 bg-zinc-100">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="relative h-[78%] w-[66%]">
          <img
            src="/images/works_1.png"
            alt="Proyecto"
            class="absolute top-[18%] left-[20%] z-10 h-[40%] w-[35%] object-cover"
          />
          <img
            src="/images/works_1.png"
            alt="Proyecto"
            class="absolute top-[4%] left-[36%] z-30 h-[45%] w-[38%] object-cover"
          />
          <img
            src="/images/works_1.png"
            alt="Proyecto"
            class="absolute top-[20%] right-[18%] z-20 h-[37%] w-[34%] object-cover"
          />
          <img
            src="/images/works_1.png"
            alt="Proyecto"
            class="absolute bottom-[7%] left-[27%] z-40 h-[40%] w-[36%] object-cover"
          />
          <img
            src="/images/works_1.png"
            alt="Proyecto"
            class="absolute right-[17%] bottom-[10%] z-50 h-[38%] w-[35%] object-cover"
          />
        </div>
      </div>
      <div class="absolute top-0 right-6 pt-10 md:right-5 md:pt-14">
        <span
          class="font-archivo inline-block text-base text-zinc-900 [writing-mode:vertical-rl] md:text-lg lg:text-2xl"
        >
          Tripulación
        </span>
      </div>
    </div>
  </section>

  <section id="contacto" class="relative flex min-h-[68vh] w-full bg-cyan-950 py-10 md:py-14">
    <div class="flex w-1/2 items-center justify-center px-8 md:px-12">
      <form
        action="/api/contact"
        method="post"
        data-contact-form
        class="w-full max-w-md space-y-3"
      >
        <input
          type="text"
          name="nombre"
          placeholder="Nom*"
          required
          class="w-full rounded-2xl bg-amber-50 px-5 py-2 text-center text-zinc-800 outline-none"
        />
        <input
          type="email"
          name="email"
          placeholder="E-mail*"
          required
          class="w-full rounded-2xl bg-amber-50 px-5 py-2 text-center text-zinc-800 outline-none"
        />
        <input
          type="tel"
          name="telefono"
          placeholder="Telèfon"
          class="w-full rounded-2xl bg-amber-50 px-5 py-2 text-center text-zinc-800 outline-none"
        />
        <textarea
          name="mensaje"
          rows="4"
          placeholder="Projecte / Idea
Deixa'm un missatge"
          class="w-full resize-none rounded-2xl bg-amber-50 px-5 py-4 text-center text-zinc-800 outline-none"
        ></textarea>
        <div class="space-y-1 text-amber-50">
          <label class="flex items-center gap-2">
            <input type="checkbox" name="politica" class="accent-amber-50" required />
            <span>Accepto la política de protecció de dades</span>
          </label>
          <label class="flex items-center gap-2">
            <input type="checkbox" name="comerciales" class="accent-amber-50" />
            <span>Accepto rebre novetats comercials</span>
          </label>
        </div>
        <div class="flex justify-end">
          <button
            type="submit"
            class="font-archivo rounded-2xl bg-cyan-900 px-4 py-1 text-amber-50 hover:bg-cyan-800"
          >
            enviar
          </button>
        </div>
        <p
          id="contact-feedback"
          class="hidden rounded-xl px-4 py-2 text-sm text-amber-50"
        >
          
        </p>
      </form>
    </div>
    <div class="relative flex w-1/2 items-center justify-center px-8 md:px-12">
      <h2
        class="font-archivo text-center text-[18vw] leading-[0.95] tracking-tight text-amber-50 md:text-[14vw] lg:text-[11vw] xl:text-[10vw]"
      >
        <span class="block">TRABA</span>
        <span class="block">JEMOS</span>
        <span class="block">JUNTOS</span>
      </h2>
    </div>
    <div class="absolute top-0 right-6 pt-10 md:right-5 md:pt-14">
      <span
        class="font-archivo inline-block text-base text-amber-50 [writing-mode:vertical-rl] md:text-lg lg:text-2xl"
      >
        Embárcate
      </span>
    </div>
  </section>

  <section id="visitanos" class="w-full bg-white">
    <div class="grid grid-cols-1 md:grid-cols-[58%_42%]">
      <div>
        <div class="relative">
          <iframe
            title="Mapa Estudi Norai"
            src="https://www.google.com/maps?q=Carrer+del+Carme+8,+Palma+de+Mallorca&output=embed"
            class="h-[460px] w-full border-0 md:h-[560px]"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
        <div class="relative -mt-2 w-full px-4 py-2 md:px-6 md:py-3">
          <h2
            class="font-archivo pointer-events-none block w-full text-[16vw] leading-none whitespace-nowrap text-stone-300 md:text-[8.8vw]"
          >
            VISÍTANOS
          </h2>
        </div>
      </div>
      <div
        class="relative flex h-[460px] items-end justify-end pr-6 pb-6 md:h-[560px] md:pr-8 md:pb-8"
      >
        <span
          class="font-archivo absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -rotate-12 text-2xl text-zinc-700 md:text-3xl"
          >o ponte en contacto</span
        >
        <div class="text-right text-3xl leading-tight text-zinc-800 md:text-4xl">
          <p>C/del Carme, 8</p>
          <p>Palma de Mallorca</p>
          <p>+34 668 900 448</p>
          <p>estudio-norai@gmail.com</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const workSection = document.getElementById('work');
    const fallingImage = document.getElementById('falling-image');
    const contactForm = document.querySelector('[data-contact-form]');
    const contactFeedback = document.getElementById('contact-feedback');

    const setContactFeedback = (type: 'ok' | 'error', message: string) => {
      if (!contactFeedback) {
        return;
      }

      contactFeedback.textContent = message;
      contactFeedback.classList.remove('hidden', 'bg-emerald-800/70', 'bg-red-900/70');
      contactFeedback.classList.add('block');

      if (type === 'ok') {
        contactFeedback.classList.add('bg-emerald-800/70');
      } else {
        contactFeedback.classList.add('bg-red-900/70');
      }
    };

    if (contactForm instanceof HTMLFormElement) {
      contactForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        const submitButton = contactForm.querySelector('button[type="submit"]');
        const originalButtonText = submitButton?.textContent;

        if (submitButton) {
          submitButton.setAttribute('disabled', 'true');
          submitButton.textContent = 'enviando...';
        }

        try {
          const response = await fetch(contactForm.action, {
            method: 'POST',
            body: new FormData(contactForm),
            headers: {
              Accept: 'application/json',
              'X-Requested-With': 'XMLHttpRequest',
            },
          });

          const result = await response.json().catch(() => null);

          if (response.ok && result?.ok) {
            setContactFeedback('ok', result.message ?? 'Mensaje enviado correctamente.');
            contactForm.reset();
          } else {
            setContactFeedback('error', result?.message ?? 'No se ha podido enviar el mensaje.');
          }
        } catch {
          setContactFeedback('error', 'Error de conexion. Vuelve a intentarlo.');
        } finally {
          if (submitButton) {
            submitButton.removeAttribute('disabled');
            submitButton.textContent = originalButtonText ?? 'enviar';
          }
        }
      });
    }

    if (workSection && fallingImage) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // Remove the class first to reset the animation
              fallingImage.classList.remove('animate-fall');
              // Force a reflow to ensure the class removal is processed
              void fallingImage.offsetWidth;
              // Add the class back to trigger the animation
              fallingImage.classList.add('animate-fall');
            }
          });
        },
        {
          threshold: 0.3, // Trigger when 30% of the section is visible
        },
      );

      observer.observe(workSection);
    }
  </script>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="flex h-screen">
    <div class="h-full w-[62%]">
      <img src="/images/door_home.jpg" class="h-full w-full object-cover object-[50%_50%]" />
    </div>
    <div class="relative h-full w-[38%] bg-amber-50">
      <nav aria-label="Sections" class="absolute inset-0">
        <a href="#estudi" class="font-archivo absolute top-[25%] left-[25%] text-4xl">l’estudi</a>
        <a href="#work" class="font-archivo absolute top-[40%] right-[30%] text-5xl">WORK</a>
        <a href="#material" class="font-archivo absolute top-[60%] left-[25%] text-4xl">material</a>
        <a href="#classes" class="font-archivo absolute right-[35%] bottom-[25%] text-4xl"
          >classes</a
        >
      </nav>
    </div>
  </section>

  <section class="absolute bottom-0 left-0 z-10 w-full bg-cyan-950 py-4">
    <div class="text-center text-sm tracking-wide text-white uppercase">
      TALLER DE PRODUCCIÓ MÚSICA I ESCOLA DE MÚSICA A PALMA
    </div>
  </section>

  <section id="intro" class="py-16">
    <div class="mx-auto max-w-5xl px-6 sm:px-8 lg:px-12">
      <p class="text-center text-[25px] leading-[32px]">
        <span class="block"
          >Norai és un estudi de producció audiovisual al centre de Palma, on el so i la imatge es
          converteixen en experiències úniques. Com el norai que ferm les barques al port, és el
          punt d’ancoratge per a qualsevol projecte creatiu. Oferim serveis d’enregistrament,
          mescla, producció musical i creació de contingut audiovisual.</span
        >
        <span class="block">Un espai on les idees prenen forma i troben el seu propi ritme.</span>
      </p>
    </div>
  </section>

  <section id="work" class="flex h-[70vh]">
    <div class="relative flex w-[60%] items-end justify-center bg-cyan-950 p-8">
      <h2 class="font-archivo text-[12rem] font-extralight text-amber-50">WORKS</h2>
    </div>

    <!-- Right side (40%) - White background with project title -->
    <div class="relative w-[50%] bg-white p-8">
      <img
        id="falling-image"
        src="/images/cat.jpg"
        alt="Work"
        class="animate-fall absolute top-0 left-[30%] h-60 w-45 object-cover"
      />
      <img
        id="falling-image"
        src="/images/cat.jpg"
        alt="Work"
        class="animate-fall absolute top-[10%] left-[20%] h-60 w-45 object-cover"
      />
    </div>
  </section>

  <script>
    const workSection = document.getElementById('work');
    const fallingImage = document.getElementById('falling-image');

    if (workSection && fallingImage) {
      const observer = new IntersectionObserver(
        (entries) => {
          console.log(entries);
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // Remove the class first to reset the animation
              fallingImage.classList.remove('animate-fall');
              // Force a reflow to ensure the class removal is processed
              void fallingImage.offsetWidth;
              // Add the class back to trigger the animation
              fallingImage.classList.add('animate-fall');
            }
          });
        },
        {
          threshold: 0.3, // Trigger when 30% of the section is visible
        },
      );

      observer.observe(workSection);
    }
  </script>
</BaseLayout>
